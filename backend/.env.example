# ==========================================
# Hajj Pilgrims Management API — Environment Variables
# ==========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/hajj_pilgrims

# ---- Security ----
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-key-min-32-chars

# ---- Application ----
APP_NAME=Hajj Pilgrims Management API
APP_VERSION=1.0.0
DEBUG=False

# ---- CORS ----
# JSON array or comma-separated origins.
# Examples: ["http://localhost:5173"] or http://localhost:5173,https://yourdomain.com
CORS_ORIGINS=["http://localhost:5173"]

# ---- AI (Gemini) ----
GEMINI_API_KEY=

# ---- Firebase (FCM Push Notifications) ----
FIREBASE_CREDENTIALS_PATH=

# ---- Server ----
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=info

# ---- Token Expiry ----
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
